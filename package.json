{

  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workspace/saito-admin dev",
    "build": "pnpm --filter @workspace/saito-admin build && cp -r artifacts/saito-admin/.next . && cp -r artifacts/saito-admin/public .",
    "start": "pnpm --filter @workspace/saito-admin start",
    "lint": "pnpm --filter @workspace/saito-admin lint",
    "typecheck": "tsc --build && pnpm -r --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.103.3",
    "@supabase/ssr": "^0.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.545.0",
    "next": "16.2.3",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
